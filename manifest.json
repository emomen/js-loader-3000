{
  "manifest_version": 3,
  "name": "Custom JS on Page Visit",
  "description": "Execute custom JavaScript on matching pages and manage site-specific scripts.",
  "version": "1.0",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "Custom JS on Page Visit",
    "default_popup": "options.html"
  }
}
